@startuml
skinparam classAttributeIconSize 0

' ===== LUT =====
entity "Look Up Table" as LUT {
  - id: Long
  - name: String
  - type: String
}

' ===== Work Details =====
class WorkDetails {
  - work_model: LUT
  - employment_type: LUT
  - job_title: LUT
  - schedule: JSON
  - branch: Branch
}

' ===== Company =====
entity Company {
  - id: Long
  - name: String
}

' ===== Branch =====
entity Branch {
  - id: Long
  - name: String
  - is_active: Boolean = true
  - company: Company
}

' ===== User Details =====
entity UserDetails {
  - id: Long
  - name: String
  - last_name: String
  - individual_identification_number: Long
  - user_group: LUT
  - company: Company
  - user: User
}

' ===== User =====
entity User {
  - id: Long
  - email: String
  - password: String
  - is_superuser: Boolean = false
  - is_first_access: Boolean = true
  - is_active: Boolean = true
}

' ===== Work Log =====
entity WorkLog {
  - id: Long
  - time: Time
  - geolocation: Point
  - status: String = "OK"
  - work_log_daily: WorkLogDaily
}

' ===== Work Log Daily =====
entity WorkLogDaily {
  - id: Long
  - date: Date
  - total_logs: Integer
  - total_adjustment: Integer
  - total_worked: Double
  - time_bank: Double
  - user: User
}

' ===== Work Log Adjustment =====
entity WorkLogAdjustment {
  - id: Long
  - time_adjust: Time
  - requested_at: Date
  - status: String = "PENDENT"
  - rejection_reason: String
  - work_log: WorkLog
  - user_adjustment: User
}

' ===== Notification =====
entity Notification {
  - id: Long
  - text: String
  - status: String = "UNREAD"
  - user: User
}

' ===== Email Service =====
class Email {
  + send(): void
}

' ===== Report Service =====
class Report <<service>> {
  + generateTimeSheet(): PDF
  + generateTimeBank(): PDF
}

' ===== Relationships =====

' LookUpTable LUT
LUT "1" o-- "1" WorkDetails
LUT "1" o-- "1" WorkDetails
LUT "1" o-- "1" WorkDetails
LUT "1" o-- "1" UserDetails

' Company
Company "1" *-- "many" Branch

' UserDetails
UserDetails "1" --* "1" User
UserDetails "1" --> "many" Company

' User dependencies (dashed)
User ..> Email
User ..> Report

' Notification
Notification "many" --> "1" User

' WorkDetails
WorkDetails "1" --o "1" Branch

' WorkLogDaily
WorkLogDaily "1" *-- "many" WorkLog
WorkLog "1" <-- "many" WorkLogAdjustment
WorkLogDaily "many" --o "1" User

' WorkLogAdjustment
WorkLogAdjustment "many" --* "1" User
@enduml
